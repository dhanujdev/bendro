# Copy to .env.local and fill in real values. All secrets are optional in dev —
# leave them blank and the app still runs against mock data.

# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# When set, the API routes hit Neon via Drizzle. When unset, they fall back to
# the in-memory seed data in src/lib/mock-data.ts.
# Example: postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PREMIUM_PRICE_ID=

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── AI (optional everywhere) ────────────────────────────────────────────────
OPENAI_API_KEY=
