# Copy to .env.local and fill in real values. All secrets are optional in dev —
# leave them blank and the app still runs against mock data.

# ─── Database (Neon Postgres) ────────────────────────────────────────────────
# When set, the API routes hit the DB via Drizzle. When unset, they fall back
# to the in-memory seed data in src/lib/mock-data.ts.
#
#   Neon:  postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require
#   Local: postgresql://bendro:bendro@localhost:5432/bendro  (see docker-compose.db.yml)
#
# For the full workflow (generate → review → migrate → seed + preview branches)
# see docs/DB_TOGGLE.md.
DATABASE_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_PREMIUM_ANNUAL_PRICE_ID=

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate: `openssl rand -hex 32`
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# Legacy aliases still honored; prefer AUTH_* going forward.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Auth providers (all optional; missing providers are hidden on the sign-in page)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=

# ─── Observability (Phase 15 — all optional; no-op when unset) ───────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── AI (optional everywhere) ────────────────────────────────────────────────
OPENAI_API_KEY=
